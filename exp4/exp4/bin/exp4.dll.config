<configuration>
	<connectionStrings>
		<add name="con"
			 connectionString="Data Source=.;Initial Catalog=Exp4DB;Integrated Security=True"
			 providerName="System.Data.SqlClient"/>
	</connectionStrings>

	<system.web>
		<compilation debug="true" targetFramework="4.7.2" />
		<httpRuntime targetFramework="4.7.2" />
	</system.web>
</configuration>