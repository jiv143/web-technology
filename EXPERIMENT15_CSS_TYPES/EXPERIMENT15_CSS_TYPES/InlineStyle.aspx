<%@ Page Language="C#" AutoEventWireup="true" %>
<body style="background-color: #1a1a2e; color: #ffffff; font-family: 'Verdana'; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0;">
    <div style="background-color: #16213e; border: 2px solid #e94560; padding: 40px; border-radius: 15px; text-align: center; box-shadow: 0 0 20px rgba(233, 69, 96, 0.3);">
        <h2 style="color: #e94560; text-transform: uppercase; letter-spacing: 2px;">Inline Mart</h2>
        <p style="color: #95a5a6; margin-bottom: 25px;">Styles are applied directly to each element.</p>
        <button style="background-color: #e94560; color: white; border: none; padding: 12px 25px; border-radius: 5px; font-weight: bold; cursor: pointer;">Action Button</button>
    </div>
</body>