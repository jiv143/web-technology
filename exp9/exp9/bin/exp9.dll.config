<?xml version="1.0" encoding="utf-8"?>

<configuration>

	<connectionStrings>
		<add name="con"
			 connectionString="Data Source=.;Initial Catalog=exp8db;Integrated Security=True"
			 providerName="System.Data.SqlClient"/>
	</connectionStrings>

	<system.web>
		<compilation debug="true" targetFramework="4.7.2">
			<assemblies>
				<add assembly="CrystalDecisions.CrystalReports.Engine" />
				<add assembly="CrystalDecisions.ReportSource" />
				<add assembly="CrystalDecisions.Shared" />
				<add assembly="CrystalDecisions.Web" />
			</assemblies>
		</compilation>
		<httpRuntime targetFramework="4.7.2" />
	</system.web>

	<system.webServer>
		<handlers>
			<add name="CrystalImageHandler"
				 path="CrystalImageHandler.aspx"
				 verb="*"
				 type="CrystalDecisions.Web.CrystalImageHandler, CrystalDecisions.Web"
				 preCondition="integratedMode"/>
		</handlers>
	</system.webServer>

</configuration>