<?xml version="1.0" encoding="utf-8"?>

<configuration>

	<!-- ================= CONNECTION STRING ================= -->
	<connectionStrings>
		<add name="con"
			 connectionString="Data Source=.;Initial Catalog=exp8db;Integrated Security=True"
			 providerName="System.Data.SqlClient" />
	</connectionStrings>

	<!-- ================= SYSTEM WEB ================= -->
	<system.web>

		<!-- Enable Debug -->
		<compilation debug="true" targetFramework="4.7.2" />

		<!-- Authentication (default) -->
		<authentication mode="None" />

		<!-- Custom Errors -->
		<customErrors mode="Off" />

	</system.web>

	<!-- ================= IIS SETTINGS ================= -->
	<system.webServer>
		<defaultDocument>
			<files>
				<add value="ListView.aspx" />
			</files>
		</defaultDocument>
	</system.webServer>

</configuration>